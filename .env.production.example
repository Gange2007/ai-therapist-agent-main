# ============================================================
# FRONTEND — Add these in Vercel Dashboard → Settings → Environment Variables
# ============================================================

# Your Render backend URL (replace with your actual Render URL after deploying backend)
NEXT_PUBLIC_API_URL=https://ai-therapist-backend.onrender.com/api

# Gemini AI Key
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth (NEXTAUTH_URL = your Vercel deployment URL)
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your_nextauth_secret_here

# ============================================================
# BACKEND — Add these in Render Dashboard → Environment
# ============================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ai-therapist?retryWrites=true&w=majority

# JWT secret (must match NEXTAUTH_SECRET above)
JWT_SECRET=your_jwt_secret_here

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

NODE_ENV=production
PORT=10000
